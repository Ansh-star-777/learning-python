from abc import ABC,abstractmethod

class Animal(ABC):
  @abstractmethod
  def make_sound(self):
    pass

class Dog(Animal):
  def make_sound(self):
    print("woof")
  def bark(self):
    print("meow")

class Cat(Animal):
  def make_sound(self):
    print("Meowwww")

dog_the_aura = Dog()
dog_the_aura.make_sound()

from abc import ABC,abstractmethod

class Country(ABC):
  @abstractmethod
  def capital(self):
    pass
  def language(self):
    pass

class India(Country):
  def capital(self):
    print("New Dehli")
  def language(self):
    print("Hindi")

class Spain(Country):
  def capital(self):
    print("Madrid")
  def language(self):
    print("Spainsh")

hala_madrid = Spain()
hala_madrid.capital()
hala_madrid.language()
